# Copy to .env and fill in. Never commit .env.

# Postgres connection (the diskduel role on the shared instance)
DATABASE_URL=postgresql+psycopg://diskduel:CHANGEME@192.168.200.50:5432/diskduel

# Shared secret the script must send via X-API-Key to upload results
DISK_DUEL_API_KEY=CHANGEME_GENERATE_WITH_OPENSSL_RAND_HEX_32

# Salt for hashids. Changing this invalidates all existing public URLs.
HASHIDS_SALT=CHANGEME_GENERATE_WITH_OPENSSL_RAND_HEX_16

# URL prefix the app is served under. Empty for root, "/disk-duel" for the
# production deployment behind a reverse proxy.
ROOT_PATH=

# Public base URL returned in API responses (run_url, machine_url).
# Used so the script can print clickable links.
PUBLIC_BASE_URL=http://localhost:8000
