# Copy to .env and fill in. Never commit .env.

# Postgres connection (the diskduel role on the shared instance)
DATABASE_URL=postgresql+psycopg://diskduel:CHANGEME@your-db-host:5432/diskduel

# Optional. Reserved for future admin endpoints (delete-run, ban-serial,
# etc.). The public POST /api/v1/runs/ endpoint is unauthenticated -- spam
# protection is proof-of-work + per-IP and per-serial rate limits.
DISK_DUEL_API_KEY=

# Anti-spam tunables. Difficulty 20 averages ~1-2 s on a recent laptop.
# Bumping it rejects older scripts; keep in sync with disk_duel.py's
# POW_DIFFICULTY_BITS.
POW_DIFFICULTY_BITS=20
SERIAL_COOLDOWN_SECONDS=60
IP_LIMIT_PER_MINUTE=30

# Salt for hashids. Changing this invalidates all existing public URLs.
HASHIDS_SALT=CHANGEME_GENERATE_WITH_OPENSSL_RAND_HEX_16

# URL prefix the app is served under. Empty for root, "/disk-duel" for the
# production deployment behind a reverse proxy.
ROOT_PATH=

# Public base URL returned in API responses (run_url, machine_url).
# Used so the script can print clickable links.
PUBLIC_BASE_URL=http://localhost:8000
